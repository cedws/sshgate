{
  // Run sshgate as a regular tsnet node without publishing a Tailscale service.
  "tsnet": {
    "enabled": true,
    "hostname": "sshgate",
    "port": 22,
    "advertise_tags": ["tag:sshgate"],
  },

  // Access rules for Tailscale clients come from the
  // github.com/cedws/sshgate app capability in the tailnet grants policy.

  // Generate this key with: ssh-keygen -t ed25519 -f sshgate-host-key
  "host_key_paths": {
    "ed25519": "./sshgate-host-key",
  },
}
